<section class="secret-page">
  <% if (!unlocked) { %>
    <div class="secret-lock">
      <h1>隐藏区域</h1>
      <form class="secret-form" method="post" action="/secret">
        <label class="secret-label" for="secretPassword">密码</label>
        <input
          class="secret-input"
          id="secretPassword"
          name="password"
          type="password"
          inputmode="numeric"
          autocomplete="current-password"
          autofocus
          required
        >
        <% if (error) { %>
          <p class="secret-error"><%= error %></p>
        <% } %>
        <button class="secret-submit" type="submit">进入</button>
      </form>
    </div>
  <% } else { %>
    <div class="secret-content">
      <header class="secret-list-header">
        <div>
          <h1>隐藏博客</h1>
          <p><%= posts.length %> 篇私密文章</p>
        </div>
        <form method="post" action="/secret/logout">
          <button class="secret-logout" type="submit">退出</button>
        </form>
      </header>

      <% if (posts.length === 0) { %>
        <p class="empty-hint">还没有私密文章。</p>
      <% } else { %>
        <div class="post-list">
          <% posts.forEach(function(post) { %>
            <article class="post-card" onclick="location.href='/secret/post/<%= post.id %>'">
              <div class="post-card-header">
                <h2 class="post-card-title">
                  <a href="/secret/post/<%= post.id %>"><%= post.title %></a>
                </h2>
                <time class="post-card-date" datetime="<%= post.date %>"><%= post.date %></time>
              </div>
              <p class="post-card-summary"><%= post.summary %></p>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% } %>
</section>
