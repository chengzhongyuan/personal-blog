<%
var wordCount = post.content.replace(/[#*`\-\|\n\r\s]/g, '').length;
var readingTime = Math.max(1, Math.round(wordCount / 400));
%>
<article class="post-detail">
  <header class="post-header">
    <div class="post-meta">
      <time class="post-meta-date" datetime="<%= post.date %>"><%= post.date %></time>
      <span class="post-meta-dot">&middot;</span>
      <span class="post-meta-reading"><%= readingTime %> min read</span>
    </div>
    <h1 class="post-title"><%= post.title %></h1>
  </header>

  <% if (post.tocTree && post.tocTree.length > 0) { %>
  <nav class="post-toc">
    <div class="post-toc-title">目录</div>
    <%
    function renderTOC(items) {
      if (!items || items.length === 0) return '';
      var html = '<ul class="post-toc-list">';
      items.forEach(function(item) {
        var hasChildren = item.children && item.children.length > 0;
        html += '<li class="post-toc-item toc-level-' + item.level + '">';
        html += '<div class="post-toc-row">';
        if (hasChildren) {
          html += '<button class="toc-toggle" aria-label="展开/折叠">';
          html += '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>';
          html += '</button>';
        }
        html += '<a class="post-toc-link" href="#' + item.slug + '">' + item.text + '</a>';
        html += '</div>';
        if (hasChildren) {
          html += renderTOC(item.children);
        }
        html += '</li>';
      });
      html += '</ul>';
      return html;
    }
    %>
    <%- renderTOC(post.tocTree) %>
  </nav>
  <% } %>

  <div class="post-body">
    <%- post.html %>
  </div>

  <%# Like Button & Comment Section %>
  <div class="post-interactions">
    <button class="like-btn" id="likeBtn" data-post-id="<%= post.id %>" aria-label="点赞">
      <svg class="like-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="like-count" id="likeCount"><%= typeof likeCount !== 'undefined' ? likeCount : 0 %></span>
    </button>

    <span class="comment-count-indicator">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <span id="commentCount"><%= typeof comments !== 'undefined' ? comments.length : 0 %></span>
    </span>
  </div>

  <section class="comment-section">
    <h3 class="comment-section-title">评论</h3>
    <form class="comment-form" id="commentForm">
      <input type="text" name="author" class="comment-input" placeholder="昵称（选填）" maxlength="50" autocomplete="off">
      <textarea name="content" class="comment-textarea" placeholder="写下你的想法..." maxlength="2000" rows="3" required></textarea>
      <div class="comment-form-footer">
        <span class="comment-char-hint" id="charHint">0 / 2000</span>
        <button type="submit" class="comment-submit-btn">发表评论</button>
      </div>
    </form>
    <div class="comment-list" id="commentList">
      <% if (typeof comments !== 'undefined') { %>
        <% comments.slice().reverse().forEach(function(c) { %>
        <div class="comment-item">
          <div class="comment-item-header">
            <span class="comment-author"><%= c.author %></span>
            <time class="comment-date"><%= new Date(c.date).toLocaleDateString('zh-CN', { year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' }) %></time>
          </div>
          <p class="comment-content"><%= c.content %></p>
        </div>
        <% }) %>
      <% } %>
    </div>
  </section>

  <footer class="post-footer">
    <a href="/" class="back-link">← 返回</a>
  </footer>
</article>

<script>
(function() {
  var postId = <%= post.id %>;

  // ===== Like =====
  var likeBtn = document.getElementById('likeBtn');
  var likeCountEl = document.getElementById('likeCount');
  var liked = false;

  likeBtn.addEventListener('click', function() {
    likeBtn.disabled = true;
    fetch('/api/post/' + postId + '/like', { method: 'POST' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        liked = data.liked;
        likeCountEl.textContent = data.count;
        likeBtn.classList.toggle('liked', data.liked);
        likeBtn.disabled = false;
      })
      .catch(function() {
        likeBtn.disabled = false;
      });
  });

  // Check initial like state
  fetch('/api/post/' + postId + '/interactions')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      liked = data.liked;
      likeBtn.classList.toggle('liked', data.liked);
      likeCountEl.textContent = data.likeCount;
      document.getElementById('commentCount').textContent = data.comments.length;
    });

  // ===== Comment Form =====
  var commentForm = document.getElementById('commentForm');
  var commentList = document.getElementById('commentList');
  var textarea = commentForm.querySelector('textarea');
  var charHint = document.getElementById('charHint');

  textarea.addEventListener('input', function() {
    charHint.textContent = textarea.value.length + ' / 2000';
  });

  commentForm.addEventListener('submit', function(e) {
    e.preventDefault();
    var author = commentForm.querySelector('input[name="author"]').value.trim();
    var content = textarea.value.trim();
    if (!content) return;

    var submitBtn = commentForm.querySelector('.comment-submit-btn');
    submitBtn.disabled = true;
    submitBtn.textContent = '提交中...';

    fetch('/api/post/' + postId + '/comments', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ author: author || '匿名', content: content })
    })
      .then(function(r) { return r.json(); })
      .then(function(comment) {
        if (comment.error) { alert(comment.error); return; }
        // Prepend new comment
        var div = document.createElement('div');
        div.className = 'comment-item';
        var dateStr = new Date(comment.date).toLocaleDateString('zh-CN', { year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit' });
        div.innerHTML = '<div class="comment-item-header"><span class="comment-author">' + escapeHTML(comment.author) + '</span><time class="comment-date">' + dateStr + '</time></div><p class="comment-content"></p>';
        div.querySelector('.comment-content').textContent = comment.content;
        commentList.insertBefore(div, commentList.firstChild);
        textarea.value = '';
        charHint.textContent = '0 / 2000';
        // Update comment count
        var count = commentList.querySelectorAll('.comment-item').length;
        document.getElementById('commentCount').textContent = count;
      })
      .catch(function() {
        alert('评论提交失败，请重试');
      })
      .finally(function() {
        submitBtn.disabled = false;
        submitBtn.textContent = '发表评论';
      });
  });

  function escapeHTML(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }
})();
</script>

<script>
// ===== TOC Collapse/Expand =====
(function() {
  var toggles = document.querySelectorAll('.toc-toggle');
  toggles.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var li = btn.closest('.post-toc-item');
      var isCollapsed = li.classList.toggle('collapsed');
      btn.classList.toggle('collapsed', isCollapsed);
    });
  });
})();
</script>
