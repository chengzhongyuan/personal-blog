<div class="page-hero">
  <h1>文章列表</h1>
  <p>记录学习与思考，一共 <%= posts.length %> 篇文章</p>
</div>

<% if (posts.length === 0) { %>
  <p class="empty-hint">还没有文章，敬请期待。</p>
<% } else { %>
  <div class="post-list">
    <% posts.forEach(function(post) { %>
      <article class="post-card" onclick="location.href='/post/<%= post.id %>'">
        <div class="post-card-header">
          <h2 class="post-card-title">
            <a href="/post/<%= post.id %>"><%= post.title %></a>
          </h2>
          <time class="post-card-date" datetime="<%= post.date %>"><%= post.date %></time>
        </div>
        <p class="post-card-summary"><%= post.summary %></p>
        <div class="post-card-footer">
          <span class="post-card-tag">技术</span>
          <a href="/post/<%= post.id %>" class="read-more">
            阅读全文
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>
