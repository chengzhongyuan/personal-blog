<div class="page-hero">
  <h1>文章</h1>
  <p><%= groups.reduce((s, g) => s + g.posts.length, 0) %> 篇文章</p>
</div>

<% if (groups.length === 0) { %>
  <p class="empty-hint">还没有文章。</p>
<% } else { %>
  <% groups.forEach(function(group) { %>
    <% if (group.name) { %>
    <div class="category-section">
      <h2 class="category-title"><%= group.name %></h2>
      <div class="post-list">
    <% } else { %>
      <div class="post-list" style="margin-top: 24px;">
    <% } %>

    <% group.posts.forEach(function(post) { %>
      <article class="post-card" onclick="location.href='/post/<%= post.id %>'">
        <div class="post-card-header">
          <h2 class="post-card-title">
            <a href="/post/<%= post.id %>"><%= post.title %></a>
          </h2>
          <time class="post-card-date" datetime="<%= post.date %>"><%= post.date %></time>
        </div>
        <p class="post-card-summary"><%= post.summary %></p>
        <div class="post-card-meta-row">
          <span class="post-card-stat">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <%= post.likeCount %>
          </span>
          <span class="post-card-stat">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <%= post.commentCount %>
          </span>
        </div>
      </article>
    <% }) %>

    <% if (group.name) { %>
      </div>
    </div>
    <% } else { %>
      </div>
    <% } %>
  <% }) %>
<% } %>
