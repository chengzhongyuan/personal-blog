<div class="page-hero">
  <h1>文章</h1>
  <p><%= posts.length %> 篇文章</p>
</div>

<% if (posts.length === 0) { %>
  <p class="empty-hint">还没有文章。</p>
<% } else { %>
  <div class="post-list">
    <% posts.forEach(function(post) { %>
      <article class="post-card" onclick="location.href='/post/<%= post.id %>'">
        <div class="post-card-header">
          <h2 class="post-card-title">
            <a href="/post/<%= post.id %>"><%= post.title %></a>
          </h2>
          <time class="post-card-date" datetime="<%= post.date %>"><%= post.date %></time>
        </div>
        <p class="post-card-summary"><%= post.summary %></p>
        <div class="post-card-footer">
          <span class="read-more">
            阅读
            <svg class="arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>
